---
/**
 * GriftRepl — Embeds the bevy_ratatui Grift REPL compiled to WASM.
 *
 * When the WASM module is available at /wasm/grift_repl.js, it loads and
 * renders the full bevy_ratatui terminal. Otherwise, a fallback JavaScript
 * REPL provides basic Grift expression evaluation.
 */
---

<div class="repl-container">
  <div class="repl-header">
    <span class="dot red"></span>
    <span class="dot yellow"></span>
    <span class="dot green"></span>
    <span>grift repl — bevy_ratatui (wasm)</span>
  </div>
  <div class="repl-body" id="grift-repl">
    <div id="repl-fallback" style="padding: 1rem; font-family: monospace; color: #c4b5fd; height: 100%; display: flex; flex-direction: column;">
      <div id="repl-output" style="flex: 1; overflow-y: auto; white-space: pre-wrap; padding-bottom: 0.5rem; min-height: 300px;">
<span style="color: #7c3aed;">Welcome to Grift REPL v1.5.0</span>
<span style="color: #908caa;">A vau-calculus Lisp interpreter — no_std, no_alloc, no unsafe</span>
<span style="color: #908caa;">Type expressions to evaluate. Try: (+ 1 2), (define! x 42), (fib 10 0 1)</span>
<span style="color: #908caa;">───────────────────────────────────────────────────────────────</span>
</div>
      <div style="display: flex; align-items: center; border-top: 1px solid #44415a; padding-top: 0.5rem;">
        <span style="color: #7c3aed; margin-right: 0.5rem;">grift&gt;</span>
        <input
          id="repl-input"
          type="text"
          style="flex: 1; background: transparent; border: none; outline: none; color: #f8f8f2; font-family: monospace; font-size: 0.9rem;"
          placeholder="Enter a Grift expression..."
          autocomplete="off"
          spellcheck="false"
        />
      </div>
    </div>
    <canvas id="grift-canvas" style="display: none;"></canvas>
  </div>
</div>

<script>
  // Attempt to load the bevy_ratatui WASM REPL
  async function initWasmRepl() {
    try {
      const resp = await fetch(import.meta.env.BASE_URL + 'wasm/grift_repl.js');
      if (!resp.ok) throw new Error('WASM module not found');
      const blob = new Blob([await resp.text()], { type: 'application/javascript' });
      const url = URL.createObjectURL(blob);
      const wasmModule = await import(/* @vite-ignore */ url);
      URL.revokeObjectURL(url);
      await wasmModule.default();

      // Hide fallback, show canvas
      const fallback = document.getElementById('repl-fallback');
      const canvas = document.getElementById('grift-canvas');
      if (fallback && canvas) {
        fallback.style.display = 'none';
        canvas.style.display = 'block';
      }
    } catch {
      // WASM not available — use the JavaScript fallback REPL
      initFallbackRepl();
    }
  }

  // Minimal fallback REPL that demonstrates Grift syntax
  function initFallbackRepl() {
    const input = document.getElementById('repl-input') as HTMLInputElement;
    const output = document.getElementById('repl-output');
    if (!input || !output) return;

    const history: string[] = [];
    let historyIndex = -1;

    // Simple s-expression evaluator for demonstration
    function evaluate(expr: string): string {
      const trimmed = expr.trim();
      if (!trimmed) return '';

      try {
        return evalSExpr(trimmed);
      } catch (e) {
        return `Error: ${e instanceof Error ? e.message : String(e)}`;
      }
    }

    function tokenize(input: string): string[] {
      const tokens: string[] = [];
      let i = 0;
      while (i < input.length) {
        if (input[i] === ' ' || input[i] === '\t' || input[i] === '\n') {
          i++;
        } else if (input[i] === ';') {
          while (i < input.length && input[i] !== '\n') i++;
        } else if (input[i] === '(' || input[i] === ')') {
          tokens.push(input[i]);
          i++;
        } else if (input[i] === "'") {
          tokens.push("'");
          i++;
        } else if (input[i] === '"') {
          let str = '"';
          i++;
          while (i < input.length && input[i] !== '"') {
            if (input[i] === '\\' && i + 1 < input.length) {
              str += input[i] + input[i + 1];
              i += 2;
            } else {
              str += input[i];
              i++;
            }
          }
          if (i < input.length) { str += '"'; i++; }
          tokens.push(str);
        } else {
          let token = '';
          while (i < input.length && ' \t\n()";'.indexOf(input[i]) === -1) {
            token += input[i];
            i++;
          }
          tokens.push(token);
        }
      }
      return tokens;
    }

    type SExpr = number | string | boolean | null | SExpr[] | { type: string; value?: unknown };

    function parse(tokens: string[]): { expr: SExpr; rest: string[] } {
      if (tokens.length === 0) throw new Error('Unexpected end of input');

      const token = tokens[0];
      const rest = tokens.slice(1);

      if (token === "'") {
        const quoted = parse(rest);
        return { expr: ['quote', quoted.expr], rest: quoted.rest };
      }

      if (token === '(') {
        const list: SExpr[] = [];
        let remaining = rest;
        while (remaining.length > 0 && remaining[0] !== ')') {
          if (remaining[0] === '.') {
            remaining = remaining.slice(1);
            const cdr = parse(remaining);
            remaining = cdr.rest;
            if (remaining[0] !== ')') throw new Error('Expected ) after dotted pair');
            remaining = remaining.slice(1);
            return { expr: [...list, '.', cdr.expr], rest: remaining };
          }
          const elem = parse(remaining);
          list.push(elem.expr);
          remaining = elem.rest;
        }
        if (remaining.length === 0) throw new Error('Unmatched (');
        return { expr: list, rest: remaining.slice(1) };
      }

      if (token === ')') throw new Error('Unexpected )');

      // Atoms
      if (token === '#t' || token === '#true') return { expr: true, rest };
      if (token === '#f' || token === '#false') return { expr: false, rest };
      if (token === '#inert') return { expr: { type: 'inert' }, rest };
      if (token === '#ignore') return { expr: { type: 'ignore' }, rest };
      if (token === '()') return { expr: null, rest };

      const num = Number(token);
      if (!isNaN(num) && token !== '') return { expr: num, rest };

      if (token.startsWith('"')) return { expr: token, rest };

      return { expr: token, rest }; // symbol
    }

    const env: Record<string, SExpr> = {
      '+': { type: 'builtin', value: '+' },
      '-': { type: 'builtin', value: '-' },
      '*': { type: 'builtin', value: '*' },
      '/': { type: 'builtin', value: '/' },
      '%': { type: 'builtin', value: '%' },
      '=': { type: 'builtin', value: '=' },
      '<': { type: 'builtin', value: '<' },
      '>': { type: 'builtin', value: '>' },
      '<=': { type: 'builtin', value: '<=' },
      '>=': { type: 'builtin', value: '>=' },
    };

    function display(val: SExpr): string {
      if (val === null) return '()';
      if (val === true) return '#t';
      if (val === false) return '#f';
      if (typeof val === 'number') return String(val);
      if (typeof val === 'string') return val;
      if (Array.isArray(val)) {
        if (val.includes('.')) {
          const dotIdx = val.indexOf('.');
          return `(${val.slice(0, dotIdx).map(display).join(' ')} . ${display(val[dotIdx + 1])})`;
        }
        return `(${val.map(display).join(' ')})`;
      }
      if (typeof val === 'object' && val !== null) {
        const obj = val as { type: string };
        if (obj.type === 'inert') return '#inert';
        if (obj.type === 'ignore') return '#ignore';
        if (obj.type === 'builtin') return `<builtin>`;
        if (obj.type === 'lambda') return `<applicative>`;
        if (obj.type === 'operative') return `<operative>`;
      }
      return String(val);
    }

    function evalExpr(expr: SExpr): SExpr {
      if (typeof expr === 'number' || typeof expr === 'boolean' || expr === null) return expr;
      if (typeof expr === 'string') {
        if (expr.startsWith('"')) return expr;
        // Symbol lookup
        if (expr in env) return env[expr];
        throw new Error(`Unbound variable: ${expr}`);
      }
      if (typeof expr === 'object' && !Array.isArray(expr)) return expr;

      // List evaluation
      if (Array.isArray(expr)) {
        if (expr.length === 0) return null;

        const op = expr[0];

        // Special forms
        if (op === 'quote') return expr[1];
        if (op === 'if') {
          const test = evalExpr(expr[1]);
          if (test === true) return evalExpr(expr[2]);
          if (test === false) return expr.length > 3 ? evalExpr(expr[3]) : null;
          throw new Error('TypeError: if test must be boolean');
        }
        if (op === 'define!') {
          const name = expr[1];
          if (typeof name !== 'string') throw new Error('define! requires a symbol');
          env[name] = evalExpr(expr[2]);
          return { type: 'inert' };
        }
        if (op === 'lambda') {
          return { type: 'lambda', value: { params: expr[1], body: expr.slice(2) } };
        }
        if (op === 'vau') {
          return { type: 'operative', value: { params: expr[1], envParam: expr[2], body: expr.slice(3) } };
        }
        if (op === 'begin') {
          let result: SExpr = { type: 'inert' };
          for (let i = 1; i < expr.length; i++) {
            result = evalExpr(expr[i]);
          }
          return result;
        }
        if (op === 'list') {
          return expr.slice(1).map(evalExpr);
        }
        if (op === 'cons') {
          const car = evalExpr(expr[1]);
          const cdr = evalExpr(expr[2]);
          if (Array.isArray(cdr)) return [car, ...cdr];
          return [car, '.', cdr];
        }
        if (op === 'car') {
          const pair = evalExpr(expr[1]);
          if (!Array.isArray(pair) || pair.length === 0) throw new Error('TypeError: car requires a pair');
          return pair[0];
        }
        if (op === 'cdr') {
          const pair = evalExpr(expr[1]);
          if (!Array.isArray(pair) || pair.length === 0) throw new Error('TypeError: cdr requires a pair');
          if (pair.includes('.')) return pair[pair.indexOf('.') + 1];
          const rest = pair.slice(1);
          return rest.length === 0 ? null : rest;
        }
        if (op === 'null?') {
          const val = evalExpr(expr[1]);
          return val === null || (Array.isArray(val) && val.length === 0);
        }
        if (op === 'pair?') {
          return Array.isArray(evalExpr(expr[1]));
        }
        if (op === 'number?') {
          return typeof evalExpr(expr[1]) === 'number';
        }
        if (op === 'eq?') {
          return evalExpr(expr[1]) === evalExpr(expr[2]);
        }
        if (op === 'not') {
          const val = evalExpr(expr[1]);
          if (typeof val !== 'boolean') throw new Error('TypeError: not requires boolean');
          return !val;
        }
        if (op === 'and') {
          for (let i = 1; i < expr.length; i++) {
            const val = evalExpr(expr[i]);
            if (val === false) return false;
            if (typeof val !== 'boolean') throw new Error('TypeError: and requires booleans');
          }
          return true;
        }
        if (op === 'or') {
          for (let i = 1; i < expr.length; i++) {
            const val = evalExpr(expr[i]);
            if (val === true) return true;
            if (typeof val !== 'boolean') throw new Error('TypeError: or requires booleans');
          }
          return false;
        }

        // Function application
        const fn = evalExpr(op);
        if (typeof fn === 'object' && fn !== null && !Array.isArray(fn)) {
          const obj = fn as { type: string; value?: unknown };
          if (obj.type === 'builtin') {
            const args = expr.slice(1).map(evalExpr);
            const nums = args.map(a => {
              if (typeof a !== 'number') throw new Error(`TypeError: ${String(obj.value)} requires numbers`);
              return a as number;
            });
            switch (obj.value) {
              case '+': return nums.reduce((a, b) => a + b, 0);
              case '-': return nums.length === 1 ? -nums[0] : nums.reduce((a, b) => a - b);
              case '*': return nums.reduce((a, b) => a * b, 1);
              case '/':
                if (nums.slice(1).some(n => n === 0)) throw new Error('DivisionByZero');
                return nums.reduce((a, b) => Math.trunc(a / b));
              case '%':
                if (nums[1] === 0) throw new Error('DivisionByZero');
                return nums[0] % nums[1];
              case '=': return nums.every(n => n === nums[0]);
              case '<': return nums[0] < nums[1];
              case '>': return nums[0] > nums[1];
              case '<=': return nums[0] <= nums[1];
              case '>=': return nums[0] >= nums[1];
            }
          }
          if (obj.type === 'lambda') {
            const { params, body } = obj.value as { params: SExpr; body: SExpr[] };
            const args = expr.slice(1).map(evalExpr);
            const paramList = Array.isArray(params) ? params : [params];
            const saved: Record<string, SExpr> = {};
            paramList.forEach((p, i) => {
              if (typeof p === 'string') {
                saved[p] = env[p];
                env[p] = args[i] !== undefined ? args[i] : null;
              }
            });
            let result: SExpr = null;
            for (const b of body) {
              result = evalExpr(b);
            }
            paramList.forEach(p => {
              if (typeof p === 'string') {
                if (saved[p] !== undefined) env[p] = saved[p];
                else delete env[p];
              }
            });
            return result;
          }
        }

        throw new Error(`NotCallable: ${display(op)} is not a combiner`);
      }

      return expr;
    }

    function evalSExpr(input: string): string {
      const tokens = tokenize(input);
      if (tokens.length === 0) return '';
      const { expr } = parse(tokens);
      const result = evalExpr(expr);
      return display(result);
    }

    input.addEventListener('keydown', (e: KeyboardEvent) => {
      if (e.key === 'Enter') {
        const expr = input.value.trim();
        if (!expr) return;

        history.unshift(expr);
        historyIndex = -1;

        const line = document.createElement('div');
        line.innerHTML = `<span style="color: #7c3aed;">grift&gt;</span> ${escapeHtml(expr)}`;
        output.appendChild(line);

        const result = evaluate(expr);
        if (result) {
          const resultLine = document.createElement('div');
          const isError = result.startsWith('Error:');
          resultLine.style.color = isError ? '#ff5f56' : '#27c93f';
          resultLine.textContent = result;
          output.appendChild(resultLine);
        }

        output.scrollTop = output.scrollHeight;
        input.value = '';
      } else if (e.key === 'ArrowUp') {
        e.preventDefault();
        if (history.length > 0 && historyIndex < history.length - 1) {
          historyIndex++;
          input.value = history[historyIndex];
        }
      } else if (e.key === 'ArrowDown') {
        e.preventDefault();
        if (historyIndex > 0) {
          historyIndex--;
          input.value = history[historyIndex];
        } else {
          historyIndex = -1;
          input.value = '';
        }
      }
    });

    function escapeHtml(text: string): string {
      const div = document.createElement('div');
      div.textContent = text;
      return div.innerHTML;
    }

    input.focus();
  }

  // Initialize
  document.addEventListener('DOMContentLoaded', () => {
    initWasmRepl();
  });

  // Also try on script load (for Astro page transitions)
  if (document.readyState === 'complete' || document.readyState === 'interactive') {
    initWasmRepl();
  }
</script>
